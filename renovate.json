{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitsDisabled"
  ],
  "timezone": "UTC",
  "schedule": [
    "before 6am on monday"
  ],
  "labels": [
    "dependencies"
  ],
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "flux",
    "helm-values"
  ],
  "prConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "flux": {
    "managerFilePatterns": [
      "/^clusters\\/home\\/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/^application\\/.+\\/values(?:\\.default)?\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update devcontainer tool version ARG pins",
      "managerFilePatterns": [
        "/^\\.devcontainer\\/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?(?: versioning=(?<versioning>\\S+))?\\s+ARG [A-Z0-9_]+_VERSION=(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Update GitHub Actions tool version environment pins",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?(?: versioning=(?<versioning>\\S+))?\\s+\\s[A-Z0-9_]+_VERSION: \"?(?<currentValue>[^\"\\n]+)\"?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Update Home Assistant chart appVersion image tag",
      "managerFilePatterns": [
        "/^application\\/home-assistant\\/Chart\\.yaml$/"
      ],
      "matchStrings": [
        "appVersion:\\s+\"(?<currentValue>\\d{4}\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "homeassistant/home-assistant",
      "versioningTemplate": "regex:^(?<major>\\d{4})\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "customType": "regex",
      "description": "Update Rancher System Upgrade Controller release assets",
      "managerFilePatterns": [
        "/^clusters\\/home\\/infrastructure\\/system-upgrade-controller\\/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "github\\.com\\/rancher\\/system-upgrade-controller\\/releases\\/download\\/v(?<currentValue>[^/]+)\\/"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rancher/system-upgrade-controller",
      "versioningTemplate": "semver"
    }
  ],
  "major": {
    "dependencyDashboardApproval": true
  },
  "packageRules": [
    {
      "description": "Automerge low-risk repository maintenance tool updates after CI passes",
      "matchManagers": [
        "custom.regex",
        "dockerfile"
      ],
      "matchFileNames": [
        ".devcontainer/Dockerfile",
        ".github/workflows/**"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "repository maintenance tooling",
      "addLabels": [
        "tooling"
      ],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Keep deployed cluster changes reviewable before Flux reconciles them",
      "matchManagers": [
        "flux",
        "helm-values"
      ],
      "addLabels": [
        "cluster"
      ],
      "automerge": false
    },
    {
      "description": "Keep Home Assistant image updates reviewable before Flux reconciles them",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "homeassistant/home-assistant"
      ],
      "matchFileNames": [
        "application/home-assistant/Chart.yaml"
      ],
      "addLabels": [
        "cluster",
        "workloads"
      ],
      "automerge": false
    },
    {
      "description": "Keep System Upgrade Controller updates reviewable before Flux reconciles them",
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "rancher/system-upgrade-controller"
      ],
      "matchFileNames": [
        "clusters/home/infrastructure/system-upgrade-controller/kustomization.yaml"
      ],
      "addLabels": [
        "cluster",
        "infrastructure"
      ],
      "automerge": false
    },
    {
      "description": "Ignore removed Bitnami Shell image from disabled legacy WordPress volume permissions",
      "matchManagers": [
        "helm-values"
      ],
      "matchPackageNames": [
        "docker.io/bitnami/bitnami-shell",
        "bitnami/bitnami-shell"
      ],
      "matchFileNames": [
        "application/myenglishplayground-nl/values.default.yaml"
      ],
      "enabled": false
    },
    {
      "description": "Label Flux controller updates",
      "matchFileNames": [
        "clusters/home/flux-system/**"
      ],
      "addLabels": [
        "flux"
      ],
      "groupName": "flux controllers"
    },
    {
      "description": "Label infrastructure dependency updates",
      "matchFileNames": [
        "clusters/home/infrastructure/**"
      ],
      "addLabels": [
        "infrastructure"
      ]
    },
    {
      "description": "Label workload dependency updates",
      "matchFileNames": [
        "clusters/home/workloads/**",
        "application/home-assistant/Chart.yaml",
        "application/**/values*.yaml"
      ],
      "addLabels": [
        "workloads"
      ]
    },
    {
      "description": "Group infrastructure HelmRelease chart updates together",
      "matchFileNames": [
        "clusters/home/infrastructure/**/helmrelease.yaml"
      ],
      "groupName": "cluster infrastructure Helm releases"
    },
    {
      "description": "Upgrade Longhorn one supported minor at a time",
      "matchManagers": [
        "flux"
      ],
      "matchPackageNames": [
        "longhorn"
      ],
      "matchFileNames": [
        "clusters/home/infrastructure/longhorn/helmrelease.yaml"
      ],
      "allowedVersions": "<{{major}}.{{add minor 2}}.0",
      "groupName": "longhorn storage upgrade",
      "addLabels": [
        "longhorn",
        "storage"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Upgrade cert-manager one supported minor at a time",
      "matchManagers": [
        "flux"
      ],
      "matchPackageNames": [
        "cert-manager"
      ],
      "matchFileNames": [
        "clusters/home/infrastructure/cert-manager/helmrelease.yaml"
      ],
      "allowedVersions": "<{{major}}.{{add minor 2}}.0",
      "groupName": "cert-manager infrastructure upgrade",
      "addLabels": [
        "cert-manager",
        "infrastructure"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
