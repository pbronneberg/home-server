{
  "name": "home-server maintenance",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "ACTIONLINT_VERSION": "1.7.12",
      "CODEX_VERSION": "0.130.0",
      "GITLEAKS_VERSION": "8.30.1",
      "GIT_FILTER_REPO_VERSION": "2.47.0",
      "HELM_VERSION": "3.19.0",
      "SOPS_VERSION": "3.11.0",
      "YAMLLINT_VERSION": "1.38.0"
    }
  },
  "remoteEnv": {
    "SOPS_AGE_KEY_FILE": "${containerWorkspaceFolder}/.sops/age/keys.txt"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.vscode-github-actions",
        "openai.chatgpt",
        "redhat.vscode-yaml",
        "stateful.runme"
      ]
    }
  }
}
